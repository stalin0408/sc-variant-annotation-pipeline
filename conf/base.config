// Base configuration for all processes
process {
cpus = { check_max( 1, 'cpus' ) }
memory = { check_max( 2.GB, 'memory' ) }
time = { check_max( 1.h, 'time' ) }

errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'terminate' }
maxRetries = 3
maxErrors = '-1'

withLabel:process_high {
cpus = { check_max( 8, 'cpus' ) }
memory = { check_max( 32.GB, 'memory' ) }
time = { check_max( 24.h, 'time' ) }
}

withLabel:process_medium {
cpus = { check_max( 4, 'cpus' ) }
memory = { check_max( 16.GB, 'memory' ) }
time = { check_max( 8.h, 'time' ) }
}

withLabel:process_low {
cpus = { check_max( 2, 'cpus' ) }
memory = { check_max( 8.GB, 'memory' ) }
time = { check_max( 4.h, 'time' ) }
}
}

// Function to check maximum resources
def check_max(obj, type) {
if (type == 'cpus') {
return (obj instanceof Integer) ? Math.min( obj, params.max_cpus as int ) : obj
} else if (type == 'memory') {
return (obj instanceof MemoryUnit) ? Math.min( obj.toBytes(), params.max_memory.toBytes() as long ) : obj
} else if (type == 'time') {
return (obj instanceof Duration) ? Math.min( obj, params.max_time as Duration ) : obj
} else {
return obj
}
}

