// Global parameters
params {

    max_cpus   = 16
    max_memory = 128.GB
    max_time   = 72.h
}


// Base configuration for all processes
process {

    cpus   = 1
    memory = 2.GB
    time   = 1.h

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'terminate' }

    maxRetries = 3
    maxErrors  = '-1'


    // High-resource processes
    withLabel: process_high {

        cpus   = 16
        memory = 64.GB
        time   = 24.h
    }


    // Medium-resource processes
    withLabel: process_medium {

        cpus   = 4
        memory = 16.GB
        time   = 8.h
    }


    // Low-resource processes
    withLabel: process_low {

        cpus   = 2
        memory = 8.GB
        time   = 4.h
    }
}